# Required for the agent to actually run
ANTHROPIC_API_KEY=sk-ant-...

# Required for traces to land in Arize AX
ARIZE_SPACE_ID=
ARIZE_API_KEY=
ARIZE_PROJECT_NAME=fuad-testing-travel-agent

# Optional bearer key. If set, callers can present it via `Authorization: Bearer <key>`
# but requests without it are still accepted (logged as warnings).
API_KEY=

# Optional default model override
DEFAULT_MODEL=claude-sonnet-4-5
